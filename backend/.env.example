# Postgres connection string
DATABASE_URL=postgresql+psycopg2://dataroom_app:dataroom_dev_pw@localhost:5432/dataroom

# Flask session signing key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
FLASK_SECRET_KEY=

# Key for encrypting OAuth tokens at rest (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
TOKEN_ENCRYPTION_KEY=

# Where uploaded/imported files are written on disk
STORAGE_DIR=./storage

# Frontend origin, for CORS and post-OAuth redirects
FRONTEND_ORIGIN=http://localhost:5173

# From Google Cloud Console -> APIs & Services -> Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# Local dev only: Google's oauthlib refuses to complete the OAuth handshake
# over plain http. Never set this in production (redirect URIs there must be https).
OAUTHLIB_INSECURE_TRANSPORT=1

# Prevents a hard error when a re-consenting user's granted scopes don't
# exactly match the requested set (e.g. union of an old + new grant). Safe
# to leave set in all environments.
OAUTHLIB_RELAX_TOKEN_SCOPE=1
